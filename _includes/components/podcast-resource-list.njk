<section class="podcast-readable-list" aria-label="Podcast recommendations">
  {% for resource in resources %}
    <article class="podcast-readable-item" id="podcast-{{ loop.index0 }}">
      {% if resource.image %}
        <img
          class="podcast-readable-cover"
          src="{{ resource.image }}"
          alt="{{ resource.alt or ('Cover art for ' + resource.title) }}"
          width="200"
          height="200"
          loading="lazy"
        >
      {% endif %}
      <div class="podcast-readable-body">
        {% set tagList = resource.tags | default([]) %}
        {% if tagList %}
          <ul class="resource-tags" aria-label="Podcast tags">
            {% for tag in tagList %}
              <li class="resource-tag">{{ tag }}</li>
            {% endfor %}
          </ul>
        {% endif %}
        <h3><a href="{{ resource.link }}" rel="noreferrer noopener">{{ resource.title }}</a></h3>
        <p>{{ resource.description }}</p>
        {% if resource.favoriteEpisodes %}
          <h4>Favorite episodes</h4>
          <ul>
            {% for episode in resource.favoriteEpisodes %}
              <li>
                {% if episode.link %}
                  <a href="{{ episode.link }}" rel="noreferrer noopener">{{ episode.title }}</a>
                {% else %}
                  {{ episode.title }}
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>
    </article>
  {% endfor %}
</section>
